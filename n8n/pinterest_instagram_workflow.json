        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Pinterest_URL": "={{ $('Validate URL').first().json.pinterest_url }}",
            "Status": "PENDING",
            "Added_Date": "={{ $('Validate URL').first().json.added_date }}",
            "Posted_Date": "",
            "Instagram_Post_ID": ""
          }
        },
        "options": {}
      },
      "id": "append-to-sheet",
      "name": "Append URL to Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1200, 100],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google-sheets-cred",
          "name": "Google Sheets"
        }
      }
    },
