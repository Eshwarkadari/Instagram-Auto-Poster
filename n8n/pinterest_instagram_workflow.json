{
  "name": "Pinterest to Instagram - Google Sheets Queue System",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "add-pinterest-url",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-add-url",
      "name": "Webhook - Add URL",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 200],
      "webhookId": "add-pinterest-url"
    },
    {
      "parameters": {
        "jsCode": "// Validate and prepare Pinterest URL\nconst body = $input.first().json.body || $input.first().json;\nconst url = body.pinterest_url || body.url || '';\n\nif (!url || !url.includes('pin')) {\n  throw new Error('Invalid Pinterest URL: ' + url);\n}\n\nconst now = new Date();\nconst addedDate = now.toISOString().split('T')[0];\n\nreturn [{\n  json: {\n    pinterest_url: url.trim(),\n    status: 'PENDING',\n    added_date: addedDate\n  }\n}];"
      },
      "id": "validate-url",
      "name": "Validate URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [320, 200]
    },
    {
      "parameters": {
        "operation": "getAll",
        "documentId": { "value": "={{ $vars.GOOGLE_SHEET_ID }}" },
        "sheetName": { "value": "Sheet1" },
        "options": {}
      },
      "id": "check-duplicate",
      "name": "Read Sheet - Check Duplicate",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [540, 200],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google-sheets-cred",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Check if URL already exists in sheet\nconst newUrl = $('Validate URL').first().json.pinterest_url;\nconst rows = $input.all();\n\nconst exists = rows.some(r => {\n  const existing = r.json.Pinterest_URL || r.json.pinterest_url || '';\n  return existing.trim() === newUrl.trim();\n});\n\nif (exists) {\n  return [{ json: { is_duplicate: true, message: 'URL already in queue', url: newUrl } }];\n}\n\nreturn [{ json: { is_duplicate: false, url: newUrl } }];"
      },
      "id": "check-dup-logic",
      "name": "Check Duplicate Logic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [760, 200]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "id": "not-dup",
              "leftValue": "={{ $json.is_duplicate }}",
              "rightValue": false,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-not-duplicate",
      "name": "If Not Duplicate",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [980, 200]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": { "value": "={{ $vars.GOOGLE_SHEET_ID }}" },
