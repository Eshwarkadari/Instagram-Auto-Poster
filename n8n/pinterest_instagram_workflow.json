          ]
        }
      },
      "id": "cron-daily",
      "name": "Cron - 9AM 1PM 7PM IST",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [100, 600]
    },
    {
      "parameters": {
        "operation": "getAll",
        "documentId": { "value": "={{ $vars.GOOGLE_SHEET_ID }}" },
        "sheetName": { "value": "Sheet1" },
        "options": {
          "returnAllMatches": true
        }
      },
      "id": "read-sheet-pending",
      "name": "Read Sheet - Get All",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [320, 600],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "google-sheets-cred",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Find first PENDING URL\nconst rows = $input.all();\n\nconst pending = rows.filter(r => {\n  const status = (r.json.Status || r.json.status || '').toUpperCase();\n  return status === 'PENDING';\n});\n\nif (pending.length === 0) {\n  throw new Error('No PENDING URLs in queue. Add more Pinterest URLs!');\n}\n\n// Take first pending item\nconst item = pending[0].json;\nconst rowNumber = rows.findIndex(r => {\n  const status = (r.json.Status || r.json.status || '').toUpperCase();\n  const url = r.json.Pinterest_URL || r.json.pinterest_url || '';\n  return status === 'PENDING' && url === (item.Pinterest_URL || item.pinterest_url);\n}) + 2; // +2 for header row and 1-based index\n\nconst pinUrl = item.Pinterest_URL || item.pinterest_url || '';\n\nconsole.log(`Found PENDING URL: ${pinUrl} at row ${rowNumber}`);\nconsole.log(`Total pending: ${pending.length}`);\n\nreturn [{\n  json: {\n    pinterest_url: pinUrl,\n    row_number: rowNumber,\n    total_pending: pending.length\n  }\n}];"
      },
      "id": "find-pending",
      "name": "Find First PENDING URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [540, 600]
    },
    {
      "parameters": {
        "jsCode": "// Extract image URL from Pinterest using oEmbed\nconst pinUrl = $input.first().json.pinterest_url;\nconst oembedUrl = `https://www.pinterest.com/oembed.json?url=${encodeURIComponent(pinUrl)}`;\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    oembed_url: oembedUrl\n  }\n}];"
      },
      "id": "prep-pinterest",
      "name": "Prep Pinterest Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [760, 600]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.oembed_url }}",
        "options": {
          "timeout": 15000,
          "retry": { "enabled": true, "maxTries": 3, "waitBetweenTries": 2000 }
        }
      },
      "id": "fetch-oembed",
      "name": "Fetch Pinterest oEmbed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [980, 600]
    },
    {
      "parameters": {
        "jsCode": "// Extract and upgrade image URL\nconst data = $input.first().json;\nconst prev = $('Find First PENDING URL').first().json;\n\nlet imageUrl = data.thumbnail_url || data.url || '';\n\nif (!imageUrl) {\n  throw new Error('Could not extract image from Pinterest: ' + prev.pinterest_url);\n}\n\n// Upgrade resolution to highest quality\nconst upgrades = [['236x','originals'],['474x','originals'],['736x','originals'],['170x','originals']];\nfor (const [low, high] of upgrades) {\n  imageUrl = imageUrl.replace(low, high);\n}\n\nconsole.log('Image URL:', imageUrl);\n\nreturn [{\n  json: {\n    ...prev,\n    image_url: imageUrl,\n    pin_title: data.title || 'Fashion Outfit'\n  }\n}];"
      },
      "id": "extract-image-url",
      "name": "Extract Image URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 600]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.image_url }}",
        "options": {
          "response": { "response": { "responseFormat": "file" } },
          "timeout": 30000,
          "retry": { "enabled": true, "maxTries": 3, "waitBetweenTries": 3000 }
        }
      },
      "id": "download-image",
      "name": "Download Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1420, 600]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://catbox.moe/user/api.php",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            { "name": "reqtype", "value": "fileupload" },
            { "name": "userhash", "value": "" },
            { "name": "fileToUpload", "value": "={{ $binary.data }}", "parameterType": "formBinaryData" }
          ]
        },
        "options": {
          "timeout": 30000,
          "retry": { "enabled": true, "maxTries": 3, "waitBetweenTries": 3000 }
        }
      },
      "id": "upload-image",
      "name": "Upload to Public Host",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1640, 600]
    },
    {
      "parameters": {
        "jsCode": "// Get public URL + build fixed Instagram caption\nconst uploadResp = $input.first().json;\nconst prev = $('Extract Image URL').first().json;\n\nlet publicUrl = '';\nif (typeof uploadResp === 'string' && uploadResp.startsWith('https://')) {\n  publicUrl = uploadResp.trim();\n} else if (uploadResp.body && uploadResp.body.startsWith('https://')) {\n  publicUrl = uploadResp.body.trim();\n} else {\n  // fallback to original Pinterest image URL\n  publicUrl = prev.image_url;\n  console.log('Using Pinterest image URL as fallback');\n}\n\nconsole.log('Public URL:', publicUrl);\n\n// Fixed caption as specified\nconst caption = `🔥 Men's Fashion Inspiration\\n\\nUpgrade your wardrobe with timeless style and confidence.\\n\\n💬 Comment \"LINK\" for product links\\n📌 Save this look for later\\n👔 Follow @styleformenindia for daily men's fashion inspiration\\n\\n#mensfashion #mensstyle #outfitideas #fashion #style #menswear #streetwear #casualstyle #outfitinspiration #styleformen #fashionreels #indianmensfashion #dailyoutfit #styleinspo #fashiontips`;\n\nreturn [{\n  json: {\n    ...prev,\n    public_image_url: publicUrl,\n    caption: caption\n  }\n}];"
      },
      "id": "build-caption",
      "name": "Build Caption",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1860, 600]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{ $vars.INSTAGRAM_ACCOUNT_ID }}/media",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "image_url", "value": "={{ $json.public_image_url }}" },
            { "name": "caption", "value": "={{ $json.caption }}" },
            { "name": "access_token", "value": "={{ $vars.INSTAGRAM_ACCESS_TOKEN }}" }
          ]
        },
        "options": {
          "timeout": 30000,
          "retry": { "enabled": true, "maxTries": 3, "waitBetweenTries": 5000 }
        }
      },
