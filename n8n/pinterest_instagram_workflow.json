    {
      "parameters": {
        "jsCode": "// Prepare sheet update data\nconst publishResp = $input.first().json;\nconst prev = $('Build Caption').first().json;\n\nconst postId = publishResp.id || 'unknown';\nconst now = new Date().toISOString().replace('T',' ').substring(0,19);\n\nconsole.log('Published! Post ID:', postId);\n\nreturn [{\n  json: {\n    ...prev,\n    instagram_post_id: postId,\n    posted_date: now\n  }\n}];"
      },
