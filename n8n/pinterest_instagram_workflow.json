    {
      "parameters": {
        "jsCode": "// Handle errors - mark as FAILED\nconst error = $input.first().json;\nconst pinterestUrl = $('Find First PENDING URL').first()?.json?.pinterest_url || 'unknown';\n\nconsole.error('Pipeline failed for:', pinterestUrl);\nconsole.error('Error:', JSON.stringify(error));\n\nreturn [{\n  json: {\n    pinterest_url: pinterestUrl,\n    error: error.message || JSON.stringify(error).substring(0,200),\n    failed_at: new Date().toISOString()\n  }\n}];"
      },
