{
  "name": "Instagram Auto Poster - Pinterest → GitHub → Instagram",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "hours", "hoursInterval": 8 }
          ]
        }
      },
      "id": "node-schedule",
      "name": "Schedule Trigger (Every 8 Hours)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.github.com/repos/Eshwarkadari/Instagram-Auto-Poster/contents/links.txt",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer ={{ $env.GITHUB_TOKEN }}"
            },
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            }
          ]
        },
        "options": {}
      },
      "id": "node-get-links",
      "name": "Get links.txt from GitHub",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "const base64Content = $input.first().json.content;\nconst sha = $input.first().json.sha;\nconst decoded = Buffer.from(base64Content, 'base64').toString('utf-8');\n\nconst allLinks = decoded.split('\\n').map(l => l.trim()).filter(l => l.length > 0);\n\nif (allLinks.length === 0) {\n  throw new Error('No links found in links.txt - please add Pinterest links!');\n}\n\nconst linksToPost = allLinks.slice(0, 3);\nconst remainingLinks = allLinks.slice(3);\n\nreturn [{\n  json: {\n    linksToPost,\n    remainingLinks,\n    sha,\n    totalLinks: allLinks.length\n  }\n}];"
      },
      "id": "node-parse-links",
      "name": "Parse & Pick 3 Links",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "fieldToSplitOut": "linksToPost",
        "options": {}
      },
      "id": "node-split",
      "name": "Split Into Individual Links",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [900, 300]
    },
    {
      "parameters": {
        "jsCode": "const pinUrl = $input.first().json.linksToPost;\nconst oembedUrl = `https://www.pinterest.com/oembed.json?url=${encodeURIComponent(pinUrl)}`;\n\nreturn [{\n  json: {\n    pinUrl,\n    oembedUrl\n  }\n}];"
      },
      "id": "node-prep-pinterest",
      "name": "Prepare Pinterest URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.oembedUrl }}",
        "options": {}
      },
      "id": "node-pinterest-oembed",
      "name": "Fetch Pinterest oEmbed Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst pinUrl = $('Prepare Pinterest URL').first().json.pinUrl;\n\nlet imageUrl = data.thumbnail_url || data.url || '';\nconst title = data.title || 'Beautiful inspiration';\nconst authorName = data.author_name || '';\n\nif (imageUrl.includes('236x')) {\n  imageUrl = imageUrl.replace('236x', '736x');\n} else if (imageUrl.includes('474x')) {\n  imageUrl = imageUrl.replace('474x', '736x');\n}\n\nif (!imageUrl) {\n  throw new Error('Could not extract image from Pinterest: ' + pinUrl);\n}\n\nreturn [{\n  json: {\n    imageUrl,\n    title,\n    authorName,\n    pinUrl\n  }\n}];"
      },
      "id": "node-extract-image",
      "name": "Extract Image URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "jsCode": "const title = $input.first().json.title || 'Inspiration';\n\nconst templates = [\n  `✨ ${title}\\n\\nDouble tap if this inspires you! 💫\\n\\n#inspiration #motivation #lifestyle #aesthetic #vibes #photooftheday #instagood #instagram #beautiful #trending`,\n  `🌟 ${title}\\n\\nSave this for later! 📌\\n\\n#savethis #daily #mindset #goals #positivity #lifestyle #aesthetic #love #instadaily #viral`,\n  `💡 ${title}\\n\\nTag someone who needs to see this! 👇\\n\\n#tagsomeone #trending #explore #instagram #motivation #beautiful #art #creative #daily #inspo`,\n  `🔥 ${title}\\n\\nAgree? Drop a ❤️ below!\\n\\n#trending #explore #reels #instagram #viral #aesthetic #lifestyle #goals #amazing #photooftheday`,\n  `🎯 ${title}\\n\\nFollow for more daily inspiration! ✨\\n\\n#follow #daily #inspiration #lifestyle #mood #aesthetic #beautiful #instagood #love #trending`\n];\n\nconst caption = templates[Math.floor(Math.random() * templates.length)];\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    caption\n  }\n}];"
      },
      "id": "node-generate-caption",
      "name": "Generate Caption",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://graph.facebook.com/v19.0/1108019899065402/media",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "image_url",
              "value": "={{ $json.imageUrl }}"
            },
            {
              "name": "caption",
              "value": "={{ $json.caption }}"
            },
            {
              "name": "access_token",
              "value": "={{ $env.INSTAGRAM_ACCESS_TOKEN }}"
            }
          ]
        },
        "options": {}
      },
      "id": "node-create-container",
      "name": "Create Instagram Media Container",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2000, 300]
    },
    {
      "parameters": {
        "amount": 15,
        "unit": "seconds"
      },
      "id": "node-wait",
      "name": "Wait 15 Seconds",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [2220, 300],
      "webhookId": "wait-instagram-publish"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://graph.facebook.com/v19.0/1108019899065402/media_publish",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "creation_id",
              "value": "={{ $('Create Instagram Media Container').first().json.id }}"
            },
            {
              "name": "access_token",
              "value": "={{ $env.INSTAGRAM_ACCESS_TOKEN }}"
            }
          ]
        },
        "options": {}
      },
      "id": "node-publish",
      "name": "Publish to Instagram",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2440, 300]
    },
    {
      "parameters": {
        "jsCode": "const postedLink = $('Prepare Pinterest URL').first().json.pinUrl;\nreturn [{ json: { postedLink } }];"
      },
      "id": "node-collect-posted",
      "name": "Collect Posted Link",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2660, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://api.github.com/repos/Eshwarkadari/Instagram-Auto-Poster/contents/posted.txt",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer ={{ $env.GITHUB_TOKEN }}"
            },
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            }
          ]
        },
        "options": {}
      },
      "id": "node-get-posted",
      "name": "Get posted.txt from GitHub",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2880, 300]
    },
    {
      "parameters": {
        "jsCode": "const existingBase64 = $input.first().json.content || '';\nconst postedSha = $input.first().json.sha || '';\nconst existingContent = existingBase64 ? Buffer.from(existingBase64, 'base64').toString('utf-8') : '';\n\nconst newPostedLinks = $('Collect Posted Link').all().map(item => item.json.postedLink);\nconst allPosted = (existingContent.trim() + '\\n' + newPostedLinks.join('\\n')).trim();\nconst newPostedBase64 = Buffer.from(allPosted).toString('base64');\n\nconst remainingLinks = $('Parse & Pick 3 Links').first().json.remainingLinks;\nconst newLinksContent = remainingLinks.join('\\n');\nconst newLinksBase64 = Buffer.from(newLinksContent).toString('base64');\nconst linksSha = $('Parse & Pick 3 Links').first().json.sha;\n\nreturn [{\n  json: {\n    newPostedBase64,\n    postedSha,\n    newLinksBase64,\n    linksSha\n  }\n}];"
      },
      "id": "node-prep-update",
      "name": "Prepare GitHub Updates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3100, 300]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "https://api.github.com/repos/Eshwarkadari/Instagram-Auto-Poster/contents/posted.txt",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer ={{ $env.GITHUB_TOKEN }}"
            },
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "message", "value": "Auto: moved posted links" },
            { "name": "content", "value": "={{ $json.newPostedBase64 }}" },
            { "name": "sha", "value": "={{ $json.postedSha }}" }
          ]
        },
        "options": {}
      },
      "id": "node-update-posted",
      "name": "Update posted.txt on GitHub",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3320, 300]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "https://api.github.com/repos/Eshwarkadari/Instagram-Auto-Poster/contents/links.txt",
