        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "message", "value": "Auto: removed posted links" },
            { "name": "content", "value": "={{ $('Prepare GitHub Updates').first().json.newLinksBase64 }}" },
            { "name": "sha", "value": "={{ $('Prepare GitHub Updates').first().json.linksSha }}" }
          ]
        },
        "options": {}
      },
      "id": "node-update-links",
      "name": "Update links.txt on GitHub",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3540, 300]
    }
  ],
