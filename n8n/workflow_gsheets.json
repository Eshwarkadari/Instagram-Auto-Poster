      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2300, 500]
    },
    {
      "parameters": {
        "jsCode": "const postId = $input.first().json.id || 'unknown';\nconst now = new Date().toISOString().replace('T',' ').substring(0,19);\nconst prev = $('Build Caption').first().json;\nconsole.log('Posted! ID:', postId);\nreturn [{ json: { ...prev, post_id: postId, posted_at: now } }];"
      },
      "id": "prep-update",
      "name": "Prep Update",
      "type": "n8n-nodes-base.code",
